# ============================================
# NextStepAI — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# Nunca commite o arquivo .env.local no repositório.
# ============================================

# --------------------------------------------
# LLM — Groq (GPT OSS 120B 128k)
# --------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# Supabase (PostgreSQL + pgvector)
# --------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------
# Embeddings — OpenAI (text-embedding-3-small)
# Necessário apenas se usar embeddings da OpenAI.
# Caso use all-MiniLM-L6-v2 local, pode deixar vazio.
# --------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# Cloudflare R2 (Armazenamento de PDFs)
# --------------------------------------------
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=nextstepai-curriculos
R2_ENDPOINT=https://xxxxxxxxxxxx.r2.cloudflarestorage.com

# --------------------------------------------
# Tavily API (Busca web para recursos educacionais)
# --------------------------------------------
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# NextAuth.js v5 (Autenticação)
# --------------------------------------------
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# OAuth — Google (Provedor de login)
# --------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# OAuth — GitHub (Provedor de login)
# --------------------------------------------
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx