{
  "name": "nextstep-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "gerar-vagas": "tsx scripts/gerar-vagas-sinteticas.ts",
    "popular-banco": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/popular-banco.ts",
    "popular-banco:clean": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/popular-banco.ts --clean --yes",
    "popular-banco:test": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/popular-banco.ts --clean --yes --limit=5",
    "seed": "tsx scripts/popular-banco.ts",
    "seed:clean": "npm run popular-banco:clean",
    "seed:test": "npm run popular-banco:test",
    "testar-agente": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/testar-agente.ts",
    "testar-rag": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/testar-rag.ts",
    "testar-embeddings": "tsx -r tsconfig-paths/register --env-file=.env.local scripts/testar-embeddings.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@huggingface/inference": "^4.13.15",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.46",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/groq": "^1.2.0",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.5",
    "@langchain/tavily": "^1.2.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html-to-text": "^10.0.0",
    "langchain": "^1.3.5",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "progress": "^2.0.3",
    "radix-ui": "^1.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unpdf": "^1.6.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "supabase": "^2.95.6",
    "tailwindcss": "^3.4.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
